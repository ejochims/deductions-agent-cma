# Per-trial transcripts and drafted settlements — regenerated by the harness.
# Ignore all of runs/ EXCEPT the committed summary, the digest, and curated
# transcripts we keep as evidence.
runs/*
!runs/.gitkeep
!runs/results.json
!runs/digest.md
!runs/curated/
!runs/curated/**

__pycache__/
*.pyc
.venv/
